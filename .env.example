# Copy to `.env` and edit, or just export these in your shell.
# Defaults are chosen so the FREE local path works with no changes.

# LLM provider: local (Ollama, free/offline) or openai (cloud, paid)
G1_PROVIDER=local

# --- local (Ollama) ---
G1_LOCAL_MODEL=qwen2.5:3b
G1_OLLAMA_URL=http://localhost:11434/v1

# --- openai (only if G1_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# G1_OPENAI_MODEL=gpt-4o-mini

# --- robot ---
G1_IFACE=eth0
# G1_WAKE_WORD=hey g1      # optional; if set, robot ignores speech without it
